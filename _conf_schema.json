{
  "enabled": {
    "type": "bool",
    "description": "启用插件",
    "default": true
  },
  "mode": {
    "type": "string",
    "description": "工作模式",
    "default": "auto",
    "options": [
      "auto",
      "force",
      "off"
    ]
  },
  "prefer_public_url": {
    "type": "bool",
    "description": "公网链接优先直传",
    "default": true
  },
  "prefer_model_metadata_video": {
    "type": "bool",
    "description": "优先按元数据判断视频能力",
    "default": true
  },
  "fallback_behavior": {
    "type": "string",
    "description": "失败处理",
    "default": "keep_text",
    "options": [
      "keep_text",
      "silent"
    ]
  },
  "max_base64_mb": {
    "type": "int",
    "description": "base64 大小上限（MB）",
    "default": 20
  },
  "qwen_fps": {
    "type": "float",
    "description": "Qwen 抽帧频率",
    "default": 2.0
  },
  "generic_fps": {
    "type": "float",
    "description": "通用抽帧频率",
    "default": 2.0
  },
  "kimi_strategy": {
    "type": "string",
    "description": "Kimi 处理策略",
    "default": "auto",
    "options": [
      "auto",
      "upload",
      "base64"
    ]
  },
  "kimi_upload_on_oversize": {
    "type": "bool",
    "description": "超限时尝试 Kimi 上传",
    "default": true
  },
  "kimi_api_base": {
    "type": "string",
    "description": "Kimi API Base",
    "default": ""
  },
  "max_videos_per_message": {
    "type": "int",
    "description": "单条消息缓存上限",
    "default": 3
  },
  "max_videos_per_request": {
    "type": "int",
    "description": "单次请求注入上限",
    "default": 1
  },
  "cache_ttl_seconds": {
    "type": "int",
    "description": "缓存时长（秒）",
    "default": 7200
  },
  "cache_max_entries": {
    "type": "int",
    "description": "全局缓存上限",
    "default": 500
  },
  "remove_default_video_text": {
    "type": "bool",
    "description": "移除默认视频提示",
    "default": true
  },
  "allow_direct_video": {
    "type": "bool",
    "description": "允许直发媒体注入",
    "default": false
  },
  "intercept_direct_video_llm_request": {
    "type": "bool",
    "description": "拦截未引用媒体请求",
    "default": true
  },
  "provider_allowlist": {
    "type": "list",
    "description": "启用关键字",
    "default": []
  },
  "provider_denylist": {
    "type": "list",
    "description": "禁用关键字",
    "default": []
  },
  "video_caption_provider_id": {
    "type": "string",
    "description": "视频转述模型",
    "default": "",
    "_special": "select_provider",
    "hint": "留空则直接把 video_url 注入当前聊天模型"
  },
  "video_caption_prompt": {
    "type": "text",
    "description": "视频转述提示词",
    "hint": "这里写给转述模型的提示词，可直接改成你的业务文案",
    "default": "请阅读这个视频或 GIF，并用中文转述与用户问题直接相关的内容。如果用户没有提出具体问题，就概括主要内容、关键画面、对白或字幕，以及事件顺序。不要编造没有出现的信息。"
  },
  "video_caption_use_current_question": {
    "type": "bool",
    "description": "转述时带上当前问题",
    "default": true
  },
  "enable_gif_input": {
    "type": "bool",
    "description": "按完整动图处理 GIF",
    "default": false
  }
}
